<div class="container-fluid px-4 py-5">
  <div class="row align-items-start">
    <div class="col-md-6 mb-4">
      <p class="text-muted mb-2 fs-4">Current medication</p>
      <div class="medication-card">
        <h2 class="mb-2"><%= @medication.name %></h2>
        <p class="text-muted"><%= @medication.dosage %> · <%= @medication.reminder_time %></p>
      </div>
    </div>
    <div class="col-md-6">
      <p class="text-muted mb-2 fs-4">Past conversations</p>
      <div class="mb-4">
        <% if @chats.any? %>
          <% @chats.each do |chat| %>
            <div class="medication-card mb-3 py-3 px-4">
              <%= link_to chat.title, chat_path(chat), class: "text-decoration-none" %>
              <p class="text-muted mb-0 mt-1"><%= chat.created_at.strftime("%d/%m/%Y at %H:%M") %></p>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted">There are no chats yet.</p>
        <% end %>
      </div>
      <%= button_to "New chat", medication_chats_path(@medication), class: "btn btn-primary w-100" %>
    </div>
  </div>
</div>

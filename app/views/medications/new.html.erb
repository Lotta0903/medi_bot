<div class="container-fluid px-4 py-5">
  <h1 class="fw-bold mb-4">Add a medication</h1>

  <%= simple_form_for @medication do |f| %>
    <div class="mb-4">
      <%= f.label :name, "Medication name", class: "mb-2 d-block" %>
      <input list="medications-list" name="medication[name]" id="medication_name" class="form-control" placeholder="Search or type a medication...">
      <datalist id="medications-list">
        <option value="Aspirin">
        <option value="Paracetamol">
        <option value="Ibuprofen">
        <option value="Dafalgan">
        <option value="Doliprane">
        <option value="Efferalgan">
        <option value="Nurofen">
        <option value="Amoxicillin">
        <option value="Penicillin">
        <option value="Augmentin">
        <option value="Azithromycin">
        <option value="Ciprofloxacin">
        <option value="Metronidazole">
        <option value="Doxycycline">
        <option value="Vitamin D">
        <option value="Vitamin C">
        <option value="Vitamin B12">
        <option value="Vitamin A">
        <option value="Magnesium">
        <option value="Zinc">
        <option value="Iron">
        <option value="Calcium">
        <option value="Omega 3">
        <option value="Folic Acid">
        <option value="Omeprazole">
        <option value="Pantoprazole">
        <option value="Metformin">
        <option value="Lisinopril">
        <option value="Atorvastatin">
        <option value="Levothyroxine">
        <option value="Amlodipine">
        <option value="Metoprolol">
        <option value="Albuterol">
        <option value="Ventoline">
        <option value="Prednisone">
        <option value="Sertraline">
        <option value="Xanax">
        <option value="Valium">
        <option value="Lexomil">
        <option value="Smecta">
        <option value="Immodium">
        <option value="Gaviscon">
        <option value="Aerius">
        <option value="Zyrtec">
        <option value="Telfast">
        <option value="Clarityne">
        <option value="Humex">
        <option value="Rhinadvil">
        <option value="Sudafed">
        <option value="Strepsils">
        <option value="Diflucan">
        <option value="Canesten">
        <option value="Furosemide">
        <option value="Warfarin">
        <option value="Aspegic">
        <option value="Plavix">
        <option value="Eliquis">
        <option value="Xarelto">
        <option value="Ramipril">
        <option value="Bisoprolol">
        <option value="Simvastatin">
        <option value="Rosuvastatin">
        <option value="Gabapentin">
        <option value="Pregabalin">
        <option value="Tramadol">
        <option value="Codeine">
        <option value="Morphine">
        <option value="Diclofenac">
        <option value="Voltaren">
        <option value="Celebrex">
        <option value="Colchicine">
        <option value="Allopurinol">
        <option value="Methotrexate">
        <option value="Hydroxychloroquine">
      </datalist>
    </div>

    <div class="mb-4">
      <%= f.input :dosage, label_html: { class: "mb-2 d-block" }, placeholder: "Ex: 100mg, 500mg..." %>
    </div>

    <div class="mb-4">
      <%= f.input :reminder_time, label_html: { class: "mb-2 d-block" }, placeholder: "Ex: 08:00, 20:00..." %>
    </div>

    <%= f.submit "Add medication", class: "btn btn-primary mt-3" %>
  <% end %>
</div>

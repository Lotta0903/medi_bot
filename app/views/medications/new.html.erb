<div class="container d-flex justify-content-center">
  <div class="col-md-6">
  <h1 class="fw-bold mb-4 mt-4">Add a medication</h1>

  <%= simple_form_for @medication do |f| %>
    <div class="mb-4">
      <label class="mb-2 d-block">Medication name</label>
      <select id="medication_select" class="form-control">
        <option value="">Select a medication...</option>
        <option value="Aspirin">Aspirin</option>
        <option value="Paracetamol">Paracetamol</option>
        <option value="Ibuprofen">Ibuprofen</option>
        <option value="Dafalgan">Dafalgan</option>
        <option value="Doliprane">Doliprane</option>
        <option value="Efferalgan">Efferalgan</option>
        <option value="Nurofen">Nurofen</option>
        <option value="Amoxicillin">Amoxicillin</option>
        <option value="Penicillin">Penicillin</option>
        <option value="Augmentin">Augmentin</option>
        <option value="Azithromycin">Azithromycin</option>
        <option value="Ciprofloxacin">Ciprofloxacin</option>
        <option value="Metronidazole">Metronidazole</option>
        <option value="Doxycycline">Doxycycline</option>
        <option value="Vitamin D">Vitamin D</option>
        <option value="Vitamin C">Vitamin C</option>
        <option value="Vitamin B12">Vitamin B12</option>
        <option value="Vitamin A">Vitamin A</option>
        <option value="Magnesium">Magnesium</option>
        <option value="Zinc">Zinc</option>
        <option value="Iron">Iron</option>
        <option value="Calcium">Calcium</option>
        <option value="Omega 3">Omega 3</option>
        <option value="Folic Acid">Folic Acid</option>
        <option value="Omeprazole">Omeprazole</option>
        <option value="Pantoprazole">Pantoprazole</option>
        <option value="Metformin">Metformin</option>
        <option value="Lisinopril">Lisinopril</option>
        <option value="Atorvastatin">Atorvastatin</option>
        <option value="Levothyroxine">Levothyroxine</option>
        <option value="Amlodipine">Amlodipine</option>
        <option value="Metoprolol">Metoprolol</option>
        <option value="Albuterol">Albuterol</option>
        <option value="Ventoline">Ventoline</option>
        <option value="Prednisone">Prednisone</option>
        <option value="Sertraline">Sertraline</option>
        <option value="Xanax">Xanax</option>
        <option value="Valium">Valium</option>
        <option value="Lexomil">Lexomil</option>
        <option value="Smecta">Smecta</option>
        <option value="Immodium">Immodium</option>
        <option value="Gaviscon">Gaviscon</option>
        <option value="Aerius">Aerius</option>
      </select>
    </div>

    <div class="mb-4" id="other_medication_wrapper">
      <%= f.input :name, label: false, input_html: { id: "medication_name_field" }, placeholder: "If other, type medication name" %>
    </div>

    <div class="mb-4">
      <%= f.input :dosage, label_html: { class: "mb-2 d-block" }, placeholder: "Ex: 100mg, 500mg..." %>
    </div>

    <div class="mb-4">
      <%= f.input :reminder_time, label_html: { class: "mb-2 d-block" }, placeholder: "Ex: 08:00, 20:00..." %>
    </div>

    <%= f.submit "Add medication", class: "btn btn-primary mt-3" %>
  <% end %>
  </div>
</div>

<script>
  document.getElementById('medication_select').addEventListener('change', function() {
    const wrapper = document.getElementById('other_medication_wrapper');
    const nameField = document.getElementById('medication_name_field');
    if (this.value === '') {
      wrapper.style.display = 'block';
      nameField.value = '';
    } else {
      nameField.value = this.value;
      wrapper.style.display = 'none';
    }
  });
</script>

<div class="container py-5">
  <div class="mb-5 text-center">
    <h1 class="fw-bold">My medications</h1>
    <p class="text-muted">Track your treatments and never miss a dose.</p>
  </div>

  <div class="row">
    <% @medications.each do |medication| %>
      <div class="col-md-4 mb-4">
        <div class="medication-card">
          <h5 class="fw-bold mb-2">💊 <%= medication.name %></h5>
          <p class="text-muted mb-3"><%= medication.dosage %> · <%= medication.reminder_time %></p>
          <%= button_to "View Details", medication_chats_path(medication), class: "btn btn-outline-primary btn-sm w-100" %>
        </div>
      </div>
    <% end %>
  </div>

  <%= link_to new_medication_path, class: "btn btn-primary mt-3" do %>
  Add a medication
    <i class="fa-solid fa-circle-plus"></i>
  <% end %>
</div>

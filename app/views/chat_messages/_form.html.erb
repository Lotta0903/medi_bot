<div class="medication-card mt-4">
  <div class="med-form">
  <%= simple_form_for [chat, message] do |f| %>
    <%= f.input :content, label: "Ask a question", required: true, placeholder: "Do you have any questions?" %>
    <%= f.button :submit, 'Ask MediBot', class: 'btn btn-primary w-100 mt-2' %>
  <% end %>
  </div>
</div>

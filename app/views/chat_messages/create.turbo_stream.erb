<% if @chat.title_previously_changed? %>
  <%= turbo_stream.update "chat_title", @chat.title %>
<% end %>

<%= turbo_stream.append :messages do %>
  <%= render "chat_messages/message", message: @message %>
  <%= render "chat_messages/message", message: @assistant_message %>
<% end %>

<%= turbo_stream.update :new_message do %>
  <%= render "chat_messages/form", chat: @chat, message: ChatMessage.new %>
<% end %>
